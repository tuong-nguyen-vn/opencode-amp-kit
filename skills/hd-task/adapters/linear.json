{
  "platform": "linear",
  "display_name": "Linear",
  "status": "implemented",
  "url_pattern": "linear\\.app/[^/]+/issue/([A-Z]+-\\d+)",
  "id_group": 1,
  "mcp_server": "@linear/mcp-server",
  "mcp_server_name": "linear",
  "tools": {
    "get_task":     "linear_get_issue",
    "update_task":  "linear_update_issue",
    "add_comment":  "linear_create_comment",
    "list_teams":   "linear_list_teams",
    "get_blockers": "linear_get_issue_relations",
    "list_states":  "linear_list_workflow_states",
    "link_pr":      "linear_create_attachment",
    "search":       "linear_search_issues"
  },
  "fallback_script": "scripts/adapters/linear_fallback.py",
  "workspace_url_pattern": "linear\\.app/([^/?#]+)(?:/team/([^/?#]+))?(?:/cycle/([^/?#]+))?",
  "list_issues": "linear_search_issues",
  "list_cycles": "linear_list_cycles",
  "auth": {
    "type": "env",
    "key": "LINEAR_API_KEY",
    "format": "lin_api_*",
    "get_credentials_url": "https://linear.app/settings/api"
  }
}
