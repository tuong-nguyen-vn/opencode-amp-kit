# hd-task environment variables
#
# Auth resolution chain (highest priority first):
#   1. Project root .env  (docs/tasks/.env or <project-root>/.env)
#   2. Skill directory .env  (~/.claude/skills/hd-task/.env)
#   3. Shell environment variable  (export LINEAR_API_KEY=...)
#
# Copy this file to .env and fill in your values.
# IMPORTANT: Never commit .env to version control.

# Linear API key -- required for Linear adapter
# Format: lin_api_xxxxxxxxxxxxxxxxxxxxxxxx
# Obtain at: https://linear.app/settings/api
LINEAR_API_KEY=lin_api_xxxxxxxxxxxxxxxxxxxxxxxx

# Jira -- required for Jira adapter (all 3 vars needed)
# Obtain token at: https://id.atlassian.com/manage-profile/security/api-tokens
# JIRA_URL=https://yourcompany.atlassian.net
# JIRA_EMAIL=you@yourcompany.com
# JIRA_API_TOKEN=

# ClickUp -- required for ClickUp adapter
# Obtain at: https://app.clickup.com/settings/apps
# CLICKUP_API_TOKEN=

# Asana -- required for Asana adapter (MCP: @roychri/mcp-server-asana)
# Obtain at: https://app.asana.com/0/my-apps
# ASANA_ACCESS_TOKEN=
